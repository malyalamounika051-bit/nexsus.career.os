PORT=5000
MONGO_URI=mongodb://localhost:27017/nexus_career_os
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
NODE_ENV=development

# Demo account (auto-created by seed script)
DEMO_EMAIL=demo@nexus.com
DEMO_PASSWORD=demo1234

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# LinkedIn OAuth (https://www.linkedin.com/developers)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/auth/linkedin/callback

FRONTEND_URL=http://localhost:5173

# AI Chatbot
GEMINI_API_KEY=your_gemini_api_key

# SMTP Email Configuration (Gmail)
# 1. Enable 2-Step Verification on your Google account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Use that 16-character app password below (NOT your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
FROM_NAME=Nexus Career OS
FROM_EMAIL=your_gmail@gmail.com
